{
  "name": "sandy",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "dist/entrypoint-main.js",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "prepare:matrix-crypto": "bun ./scripts/prepare-matrix-crypto-binary.mjs",
    "knip": "knip",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist bin",
    "build:bundle": "mkdir -p dist && bun ./scripts/build-with-constants.mjs ./src/entrypoint-main.ts ./src/entrypoint-local-test.ts ./src/entrypoint-updater.ts ./src/entrypoint-worker.ts ./src/entrypoint-mcp-proxy.ts --outdir dist --target bun --sourcemap",
    "build:exe": "bun run prepare:matrix-crypto && mkdir -p bin && bun ./scripts/build-with-constants.mjs --compile --outfile bin/sandy --sourcemap ./src/entrypoint-main.ts",
    "build:exe:updater": "mkdir -p bin && bun ./scripts/build-with-constants.mjs --compile --outfile bin/sandy-updater --sourcemap ./src/entrypoint-updater.ts",
    "build:exe:worker": "mkdir -p bin && bun ./scripts/build-with-constants.mjs --compile --outfile bin/sandy-worker --sourcemap ./src/entrypoint-worker.ts",
    "build:exe:mcp": "mkdir -p bin && bun ./scripts/build-with-constants.mjs --compile --outfile bin/sandy-mcp-sidecar --sourcemap ./src/entrypoint-mcp-proxy.ts",
    "build:ci-bundle": "sh -c 'bun run clean && bun run lint && bun run typecheck && bun run build:bundle -- \"$@\" && bun run knip' --",
    "build": "bun run clean && bun run lint && bun run typecheck && bun run build:bundle && bun run knip",
    "start": "bun run src/entrypoint-main.ts",
    "start:local-test": "bun run src/entrypoint-local-test.ts",
    "test": "bun run build && bun test src"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@matrix-org/matrix-sdk-crypto-nodejs": "^0.5.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "^0.130.0",
    "grammy": "^1.42.0",
    "jsonwebtoken": "^9.0.3",
    "matrix-bot-sdk": "0.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@eslint/js": "^10.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.7.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "knip": "^6.12.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "private": true,
  "trustedDependencies": [
    "@matrix-org/matrix-sdk-crypto-nodejs"
  ]
}
