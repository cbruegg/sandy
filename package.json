{
  "name": "sandy",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "dist/index.js",
  "packageManager": "bun@1.3.12",
  "scripts": {
    "knip": "knip",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist bin",
    "build:bundle": "mkdir -p dist && bun build ./src/index.ts ./src/subagent/worker.ts ./src/mcp/sidecar.ts --outdir dist --target bun --sourcemap",
    "build:exe": "mkdir -p bin && bun build --compile --outfile bin/sandy --sourcemap ./src/index.ts",
    "build:exe:worker": "mkdir -p bin && bun build --compile --outfile bin/sandy-worker --sourcemap ./src/subagent/worker.ts",
    "build:exe:mcp": "mkdir -p bin && bun build --compile --outfile bin/sandy-mcp-sidecar --sourcemap ./src/mcp/sidecar.ts",
    "build": "bun run clean && bun run lint && bun run typecheck && bun run build:bundle && bun run knip",
    "start": "bun run src/index.ts",
    "test": "bun run build && bun test"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "^0.118.0",
    "grammy": "^1.41.1",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.2",
    "@eslint/js": "^10.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "knip": "^6.3.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.58.0"
  },
  "private": true
}
